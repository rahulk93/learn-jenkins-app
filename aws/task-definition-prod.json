{
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "family": "LearnJenkinsApp-TaskDefinition-Prod",
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::143555788014:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "learnjenkinsapp",
      "image": "__IMAGE__",
      "essential": true,
      "portMappings": [
        {
          "name": "nginx-80-tip",
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ]
    }
  ],
  "volumes": []
}